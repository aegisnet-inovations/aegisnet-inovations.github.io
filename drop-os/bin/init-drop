#!/bin/sh
# DROP OS single-user init (PID 1)

mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs dev /dev

# Bring up loopback
ip link set lo up

# Auto-detect and bring up first available ethernet NIC
NIC=$(ip -o link show | awk -F': ' '{print $2}' | grep -v lo | head -1)
if [ -n "$NIC" ]; then
    echo "DROP init: bringing up $NIC..."
    ip link set "$NIC" up
    # Try dhcpcd first, fall back to dhclient
    if command -v dhcpcd >/dev/null 2>&1; then
        dhcpcd "$NIC" &
    elif command -v dhclient >/dev/null 2>&1; then
        dhclient "$NIC" &
    fi
    sleep 3
    echo "DROP init: network up on $NIC"
fi

# Start Ollama LLM server
/usr/local/bin/ollama serve &
sleep 3

# Start DROP subsystems in background
/opt/drop-os/bin/drop-audio &
/opt/drop-os/bin/drop-memory &
/opt/drop-os/bin/drop-webintel &
/opt/drop-os/bin/drop-hitl &

# Start AI core in foreground — this *is* the system
exec /opt/drop-os/bin/drop-core
